{
  "name": "podium",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config web/vite.config.ts",
    "dev:api": "bun --hot server/src/index.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "build:api": "bun build server/src/index.ts --target bun --outfile dist/server.js",
    "build": "bun run build:web && bun run build:api",
    "start": "bun server/src/index.ts",
    "db:seed": "bun server/src/seed.ts",
    "lint": "eslint web/src --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "hono": "^4.9.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.36.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
